#!/bin/sh
# Versioned pre-commit hook: enable once per clone with
#   git config core.hooksPath tools
# Guards the committed build artifact and the logic suite.
node tools/build.js --check || { echo "pre-commit: index.html is stale — run: node tools/build.js"; exit 1; }
node tools/smoke.js > /dev/null || { echo "pre-commit: smoke suite failed — run: node tools/smoke.js"; exit 1; }
